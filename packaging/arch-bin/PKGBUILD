# Maintainer: Swaggyxren <valdiirr79@gmail.com>
#
# Prebuilt-binary variant of `penumbra-gui`.
# Pulls the tarball already attached to the GitHub Release rather than
# compiling from source. Use this if you don't want a Rust toolchain.
#
# Conflicts with the source-build package `penumbra-gui` because they install
# to the same paths.
#
# When bumping releases:
#   1. Update _pkgver_tag to the new release tag (e.g. v1.2.0-gui).
#   2. Update pkgver to a sortable version that matches it.
#   3. Refresh sha256sums (run `updpkgsums` or paste from the release page).

pkgname=penumbra-gui-bin
_pkgver_tag=v1.1.0-gui
pkgver=1.1.0.gui
pkgrel=1
pkgdesc="Native desktop GUI for the Penumbra MediaTek SoC flashing library (prebuilt binary)"
arch=('x86_64')
url="https://github.com/Swaggyxren/penumbraGUI"
license=('AGPL-3.0-or-later')
depends=(
    'gcc-libs'
    'glibc'
    # libusb is statically vendored into the v1.1.0-gui tarball
    # (libusb1-sys's vendored build kicks in when no system libusb is
    # detected at compile time), so this dep is technically not needed
    # by the current artifact. Listed anyway for consistency with the
    # source PKGBUILD and so future tarballs that happen to link
    # dynamically don't break end users.
    'libusb'
    'systemd-libs'
    'fontconfig'
    'freetype2'
    'libxcb'
    'libxkbcommon'
    'wayland'
)
provides=('penumbra-gui')
conflicts=('penumbra-gui')

source=(
    "penumbra-gui-linux-x86_64-${_pkgver_tag}.tar.gz::https://github.com/Swaggyxren/penumbraGUI/releases/download/${_pkgver_tag}/penumbra-gui-linux-x86_64.tar.gz"
)
sha256sums=(
    'c6f01b3f4164316820783a71af53a7a2c813da1708935a3092a146532b24b06e'
)

package() {
    cd "$srcdir/penumbra-gui-linux-x86_64"

    install -Dm755 "penumbra-gui"          "$pkgdir/usr/bin/penumbra-gui"
    install -Dm644 "penumbra-gui.desktop"  "$pkgdir/usr/share/applications/penumbra-gui.desktop"

    for size in 16 32 48 128 256; do
        install -Dm644 "icons/${size}x${size}.png" \
            "$pkgdir/usr/share/icons/hicolor/${size}x${size}/apps/penumbra-gui.png"
    done

    install -Dm644 "51-mtk-penumbra.rules" "$pkgdir/usr/lib/udev/rules.d/51-mtk-penumbra.rules"

    install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 "README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
}
