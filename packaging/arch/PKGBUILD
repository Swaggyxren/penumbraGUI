# Maintainer: Swaggyxren <valdiirr79@gmail.com>
pkgname=penumbra-gui
pkgver=1.1.0.gui
pkgrel=1
pkgdesc="Native desktop GUI for the Penumbra MediaTek SoC flashing library"
arch=('x86_64')
url="https://github.com/Swaggyxren/penumbraGUI"
license=('AGPL-3.0-or-later')
depends=(
    'gcc-libs'
    'glibc'
    'libusb'
    'fontconfig'
    'freetype2'
    'libxcb'
    'libxkbcommon'
    'wayland'
)
makedepends=(
    'rust>=1.83'
    'cargo'
    'pkgconf'
    'git'
)
source=("git+https://github.com/Swaggyxren/penumbraGUI.git#tag=v1.1.0-gui")
sha256sums=('SKIP')

prepare() {
    cd "$srcdir/penumbraGUI"
    # Vendor-lock dependencies for a reproducible build off the network.
    cargo fetch --target "$CARCH-unknown-linux-gnu"
}

build() {
    cd "$srcdir/penumbraGUI"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    # The gui crate already turns on the libusb backend via core's features
    # in gui/Cargo.toml; no extra feature flag needed here.
    cargo build --release --frozen -p penumbra-gui
}

package() {
    cd "$srcdir/penumbraGUI"

    install -Dm755 "target/release/penumbra-gui" "$pkgdir/usr/bin/penumbra-gui"

    install -Dm644 "gui/res/linux/penumbra-gui.desktop" \
        "$pkgdir/usr/share/applications/penumbra-gui.desktop"

    for size in 16 32 48 128 256; do
        install -Dm644 "gui/res/linux/icons/${size}x${size}.png" \
            "$pkgdir/usr/share/icons/hicolor/${size}x${size}/apps/penumbra-gui.png"
    done

    install -Dm644 "gui/res/linux/51-mtk-penumbra.rules" \
        "$pkgdir/usr/lib/udev/rules.d/51-mtk-penumbra.rules"

    install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 "README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 "gui/README-linux.md" "$pkgdir/usr/share/doc/$pkgname/README-linux.md"
}
